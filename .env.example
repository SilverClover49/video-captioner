# Video Captioner - Environment Configuration
# For judges: Set FIREWORKS_API_KEY and the code auto-detects Fireworks + Gemma

# Option 1: Fireworks (auto-detected if FIREWORKS_API_KEY is set)
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/gemma-4-31b-it

# Option 2: Groq (for testing)
# GROQ_API_KEY=your_groq_key_here
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_LLM_MODEL=llama-3.3-70b-versatile
# GROQ_STT_MODEL=whisper-large-v3

# Option 3: ZenAI (for testing)
# ZEN_API_KEY=your_zen_key_here
# ZEN_BASE_URL=https://opencode.ai/zen/v1
# ZEN_MODEL=mimo-v2.5-free
